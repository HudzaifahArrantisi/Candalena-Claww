# ═══════════════════════════════════════════
# Candalena Claw — Environment Template
# ═══════════════════════════════════════════

# Database Configuration
# Options: mysql, postgres, mongodb
DB_TYPE=mysql
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=openclaw

# MongoDB URI (Optional: Overrides separate host/port settings if provided)
# DB_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Table and Column Mapping (Auto-detects if left blank)
TABLE_NAME=tugas
COL_ID=
COL_TITLE=
COL_DEADLINE=
COL_COURSE=
COL_LECTURER=
COL_SEMESTER=
COL_KELAS=
COL_TELEGRAM=
COL_NOTIFIED=

# Telegram Integration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Scheduler Configuration (Cron syntax)
CRON_SCHEDULE=* * * * *

# Reminder Days (Comma-separated integers)
DEADLINE_REMIND_DAYS=3,1,0

# Notification Channels (Options: telegram, whatsapp)
NOTIFIER_CHANNELS=telegram

# Admin Alerting (Your personal Telegram User ID)
ADMIN_TELEGRAM_ID=

# Interactive Features
ENABLE_INTERACTIVE_BOT=true
ENABLE_DASHBOARD=true
PORT=3000
DASHBOARD_PORT=9090
